# Copie este arquivo para ".env" e preencha com sua chave real.
# NUNCA suba o arquivo ".env" (com a chave de verdade) pro GitHub.

# Pegue sua chave em: https://platform.openai.com/api-keys
OPENAI_API_KEY=coloque_sua_chave_aqui

# Porta COM do ELM327 (Windows). Deixe em branco para auto-detectar.
OBD_PORT=COM7

# Coloque 1 para forçar o modo demo (dados simulados), sem tentar
# conectar no ELM327 de verdade. Útil para testar a interface sem travar
# esperando o Bluetooth. Coloque 0 quando estiver no carro de verdade,
# com o ELM327 pareado.
C5_FORCE_DEMO=0

# Modelo da OpenAI a usar (rápido e barato, ideal para isso)
OPENAI_MODEL=gpt-4o-mini

# Vozes disponíveis: pt-BR-FranciscaNeural (feminina, suave) ou
# pt-BR-AntonioNeural (masculina, grave). Para o efeito de voz robótica
# (aplicado no frontend), a voz masculina costuma combinar melhor.
C5_VOICE=pt-BR-AntonioNeural

# Modelo do Whisper para transcrição de voz local (microfone).
# Opções (da mais rápida/leve pra mais precisa/pesada): tiny, base, small.
# "base" é um bom equilíbrio pra comandos curtos.
C5_WHISPER_MODEL=base
